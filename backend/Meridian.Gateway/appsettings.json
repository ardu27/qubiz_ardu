{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "employeesRoute": {
        "ClusterId": "employeesCluster",
        "Match": {
          "Path": "/api/employees/{**catch-all}"
        }
      },
      "departmentsRoute": {
        "ClusterId": "employeesCluster",
        "Match": {
          "Path": "/api/departments/{**catch-all}"
        }
      },
      "tasksRoute": {
        "ClusterId": "onboardingCluster",
        "Match": {
          "Path": "/api/tasks/{**catch-all}"
        }
      },
      "resourcesRoute": {
        "ClusterId": "onboardingCluster",
        "Match": {
          "Path": "/api/resources/{**catch-all}"
        }
      },
      "slackChannelsRoute": {
        "ClusterId": "onboardingCluster",
        "Match": {
          "Path": "/api/slack-channels/{**catch-all}"
        }
      },
      "bookingsRoute": {
        "ClusterId": "bookingCluster",
        "Match": {
          "Path": "/api/bookings/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "employeesCluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5101"
          }
        }
      },
      "onboardingCluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5102"
          }
        }
      },
      "bookingCluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5104"
          }
        }
      }
    }
  },
  "AllowedHosts": "*"
}
